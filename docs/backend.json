
{
  "entities": {
    "Book": {
      "title": "Book",
      "description": "A book in the library catalog",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "author": { "type": "string" },
        "isbn": { "type": "string" },
        "genre": { "type": "string" },
        "description": { "type": "string" },
        "copies": { "type": "number" },
        "available": { "type": "number" },
        "price": { "type": "number" },
        "status": { "type": "string", "enum": ["Available", "Low Stock", "Unavailable"] }
      },
      "required": ["title", "author", "isbn", "genre", "copies", "available", "status", "price"]
    },
    "Member": {
      "title": "Member",
      "description": "A registered library member",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "idNumber": { "type": "string", "description": "Unique member identification number" },
        "batch": { "type": "string", "description": "The student or member batch identifier" },
        "joinedDate": { "type": "string", "format": "date" },
        "status": { "type": "string", "enum": ["Active", "Suspended"] }
      },
      "required": ["name", "idNumber", "batch", "joinedDate", "status"]
    },
    "Loan": {
      "title": "Loan",
      "description": "A record of a book borrowed by a member",
      "type": "object",
      "properties": {
        "bookId": { "type": "string" },
        "memberId": { "type": "string" },
        "checkoutDate": { "type": "string", "format": "date" },
        "dueDate": { "type": "string", "format": "date" },
        "returnDate": { "type": "string", "format": "date" },
        "fineAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["Active", "Returned", "Overdue"] }
      },
      "required": ["bookId", "memberId", "checkoutDate", "dueDate", "fineAmount", "status"]
    },
    "LibraryConfig": {
      "title": "Library Configuration",
      "description": "Global settings for the library management system",
      "type": "object",
      "properties": {
        "libraryName": { "type": "string" },
        "contactEmail": { "type": "string" },
        "finePeriodDays": { "type": "number", "description": "Standard number of days allowed for a loan" },
        "fineRatePerDay": { "type": "number", "description": "Currency amount charged per day for overdue items" },
        "librarianName": { "type": "string" },
        "librarianPhotoUrl": { "type": "string" }
      },
      "required": ["libraryName", "finePeriodDays", "fineRatePerDay"]
    }
  },
  "auth": {
    "providers": ["google.com"]
  },
  "firestore": {
    "/books/{bookId}": {
      "schema": { "$ref": "#/backend/entities/Book" },
      "description": "Collection of books in the library"
    },
    "/members/{memberId}": {
      "schema": { "$ref": "#/backend/entities/Member" },
      "description": "Collection of library members"
    },
    "/loans/{loanId}": {
      "schema": { "$ref": "#/backend/entities/Loan" },
      "description": "Collection of loan records"
    },
    "/settings/{settingId}": {
      "schema": { "$ref": "#/backend/entities/LibraryConfig" },
      "description": "Collection for library-wide settings and configuration"
    }
  }
}
